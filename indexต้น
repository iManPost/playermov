<div class="layout">
  <!-- Video Column -->
  <div class="video-col">
    <div class="video-wrapper" id="vwrap">
      <video id="vid" playsinline preload="metadata"></video>

      <!-- Spinner -->
      <div class="spinner" id="spinner"><div class="spin-ring"></div></div>

      <!-- Error -->
      <div class="err-msg" id="errMsg">
        <span style="font-size:2rem">⚠️</span>
        <span id="errTxt">ไม่สามารถเล่นวิดีโอได้</span>
        <small style="color:var(--muted);font-size:.72rem">ลอง referrer หรือ URL อื่น</small>
      </div>

      <!-- Overlay Controls -->
      <div class="overlay" id="overlay">
        <div class="overlay-top">
          <span class="now-title" id="nowTitle">เลือกวิดีโอจากรายการ</span>
        </div>
        <div class="overlay-mid">
          <button class="ctrl-btn" id="btnPrev" title="ก่อนหน้า">⏮</button>
          <button class="ctrl-btn play-btn" id="btnPlay" title="เล่น/หยุด">▶</button>
          <button class="ctrl-btn" id="btnNext" title="ถัดไป">⏭</button>
        </div>
        <div class="overlay-bottom">
          <div class="progress-row">
            <div class="progress-wrap" id="progWrap">
              <div class="progress-fill" id="progFill"></div>
            </div>
            <span class="time-txt" id="timeTxt">0:00 / 0:00</span>
          </div>
          <div class="bottom-row">
            <button class="icon-btn" id="btnMute" title="ปิด/เปิดเสียง">🔊</button>
            <div class="vol-row">
              <input type="range" class="vol-slider" id="volSlider" min="0" max="1" step="0.05" value="1">
            </div>
            <span class="spacer"></span>
            <button class="icon-btn" id="btnFS" title="เต็มจอ">⛶</button>
          </div>
        </div>
      </div>
    </div>

    <!-- URL Input -->
    <div class="url-section">
      <label>เพิ่ม URL:</label>
      <input type="text" id="urlInput" placeholder="ชื่อวิดีโอ :: https://..." />
      <button onclick="addUrl()">+ เพิ่ม</button>
    </div>
    <div class="ref-note">💡 รูปแบบ: <code>ชื่อ :: url</code> หรือ url เปล่า — Referrer: Android'BOX Thai</div>

    <!-- Remote hints -->
    <div class="remote-hint">
      <span><span class="kbd">Space</span> เล่น/หยุด</span>
      <span><span class="kbd">←</span><span class="kbd">→</span> ←5s / +5s</span>
      <span><span class="kbd">↑</span><span class="kbd">↓</span> เสียง</span>
      <span><span class="kbd">N</span> ถัดไป</span>
      <span><span class="kbd">P</span> ก่อนหน้า</span>
      <span><span class="kbd">F</span> เต็มจอ</span>
      <span><span class="kbd">M</span> ปิดเสียง</span>
    </div>
  </div>

  <!-- Side Panel -->
  <div class="side-panel">
    <div class="playlist-section">
      <h2>รายการ</h2>
      <div class="playlist" id="playlist"></div>
    </div>
  </div>
</div>

