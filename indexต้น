<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  :root {
    --bg: #0a0a0f;
    --surface: #13131a;
    --surface2: #1c1c28;
    --accent: #e50914;
    --accent2: #ff6b35;
    --text: #f0f0f5;
    --muted: #7a7a9a;
    --border: #2a2a3a;
    --card-hover: #20202e;
    --playing: #e50914;
  }

  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Segoe UI', 'Noto Sans Thai', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── HEADER ── */
  header {
    background: linear-gradient(180deg, #000 0%, transparent 100%);
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
  }
  header .logo {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  header .count {
    margin-left: auto;
    font-size: .78rem;
    color: var(--muted);
    background: var(--surface2);
    padding: 3px 10px;
    border-radius: 20px;
  }

  /* ── LAYOUT ── */
  .layout {
    display: flex;
    flex-direction: column;
  }

  /* ── VIDEO WRAPPER ── */
  .video-wrapper {
    position: relative;
    background: #000;
    width: 100%;
    aspect-ratio: 16/9;
  }
  video {
    width: 100%;
    height: 100%;
    display: block;
    background: #000;
    outline: none;
  }

  /* overlay controls */
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    opacity: 0;
    transition: opacity .25s;
    background: linear-gradient(180deg, rgba(0,0,0,.55) 0%, transparent 30%, transparent 65%, rgba(0,0,0,.75) 100%);
    pointer-events: none;
  }
  .video-wrapper:hover .overlay,
  .video-wrapper.show-ctrl .overlay { opacity: 1; pointer-events: all; }

  .overlay-top {
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .now-title {
    font-size: .85rem;
    font-weight: 600;
    text-shadow: 0 1px 4px rgba(0,0,0,.8);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 80%;
  }

  .overlay-mid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
  }
  .ctrl-btn {
    background: rgba(0,0,0,.55);
    border: none;
    color: #fff;
    cursor: pointer;
    border-radius: 50%;
    width: 48px; height: 48px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    transition: background .15s, transform .1s;
    backdrop-filter: blur(4px);
  }
  .ctrl-btn:active { transform: scale(.88); }
  .ctrl-btn.play-btn { width: 60px; height: 60px; font-size: 1.6rem; background: rgba(229,9,20,.75); }
  .ctrl-btn:hover { background: rgba(229,9,20,.6); }

  .overlay-bottom {
    padding: 6px 14px 10px;
  }
  .progress-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }
  .progress-wrap {
    flex: 1;
    height: 5px;
    background: rgba(255,255,255,.2);
    border-radius: 3px;
    cursor: pointer;
    position: relative;
  }
  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
    width: 0%;
    transition: width .1s linear;
  }
  .progress-wrap::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translate(50%,-50%);
    width: 13px; height: 13px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 4px rgba(0,0,0,.5);
    display: none;
  }
  .progress-wrap:hover::after { display: block; }

  .time-txt { font-size: .72rem; color: rgba(255,255,255,.85); min-width: 80px; text-align: right; }

  .bottom-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .icon-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,.85);
    cursor: pointer;
    font-size: 1.1rem;
    padding: 5px;
    border-radius: 6px;
    display: flex; align-items: center;
    transition: color .15s;
  }
  .icon-btn:hover { color: #fff; }
  .spacer { flex: 1; }

  /* volume */
  .vol-row { display: flex; align-items: center; gap: 6px; }
  input[type=range].vol-slider {
    -webkit-appearance: none;
    width: 70px; height: 4px;
    background: rgba(255,255,255,.3);
    border-radius: 2px;
    outline: none;
  }
  input[type=range].vol-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px; height: 12px;
    background: #fff;
    border-radius: 50%;
  }

  /* spinner */
  .spinner {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .spinner.active { display: flex; }
  .spin-ring {
    width: 44px; height: 44px;
    border: 4px solid rgba(255,255,255,.15);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin .8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* error msg */
  .err-msg {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 8px;
    background: rgba(0,0,0,.7);
    font-size: .9rem;
    color: var(--accent);
    text-align: center;
    padding: 20px;
  }
  .err-msg.active { display: flex; }

  /* ── URL INPUT ── */
  .url-section {
    padding: 12px 14px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .url-section label { font-size: .75rem; color: var(--muted); white-space: nowrap; }
  .url-section input {
    flex: 1;
    min-width: 160px;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 7px 10px;
    border-radius: 8px;
    font-size: .82rem;
    outline: none;
  }
  .url-section input:focus { border-color: var(--accent); }
  .url-section button {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 7px 14px;
    border-radius: 8px;
    font-size: .82rem;
    cursor: pointer;
    font-weight: 600;
    white-space: nowrap;
  }
  .url-section button:hover { background: #c0070f; }

  /* ── REFERRER NOTE ── */
  .ref-note {
    font-size: .7rem;
    color: var(--muted);
    padding: 4px 14px 2px;
    background: var(--surface);
  }

  /* ── PLAYLIST ── */
  .playlist-section {
    padding: 10px 14px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .playlist-section h2 {
    font-size: .8rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .05em;
    margin-bottom: 10px;
  }
  .playlist {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pl-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    border-radius: 10px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background .15s, border-color .15s;
    background: var(--surface2);
  }
  .pl-item:hover { background: var(--card-hover); border-color: var(--border); }
  .pl-item.active { border-color: var(--accent); background: rgba(229,9,20,.08); }

  .pl-thumb {
    width: 52px;
    height: 74px;
    border-radius: 6px;
    object-fit: cover;
    background: var(--border);
    flex-shrink: 0;
  }
  .pl-info { flex: 1; overflow: hidden; }
  .pl-name {
    font-size: .88rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }
  .pl-group {
    font-size: .72rem;
    color: var(--muted);
    margin-top: 3px;
  }
  .pl-badge {
    font-size: .65rem;
    font-weight: 700;
    background: var(--accent);
    color: #fff;
    padding: 2px 7px;
    border-radius: 4px;
    display: none;
  }
  .pl-item.active .pl-badge { display: inline; }

  /* ── REMOTE KEYS (Android / TV) ── */
  .remote-hint {
    padding: 8px 14px;
    font-size: .7rem;
    color: var(--muted);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    border-top: 1px solid var(--border);
  }
  .remote-hint span { display: flex; align-items: center; gap: 4px; }
  .kbd {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
    font-size: .65rem;
    font-family: monospace;
  }

  /* ── LANDSCAPE (phone) ── */
  @media (max-width: 768px) and (orientation: landscape) {
    .layout {
      flex-direction: row;
      height: 100dvh;
    }
    .video-wrapper {
      flex: 1;
      aspect-ratio: unset;
      height: 100dvh;
    }
    .side-panel {
      width: 240px;
      overflow-y: auto;
      flex-shrink: 0;
      border-left: 1px solid var(--border);
    }
    header { display: none; }
  }

  /* ── PORTRAIT mobile ── */
  @media (max-width: 600px) {
    .ctrl-btn { width: 42px; height: 42px; font-size: 1rem; }
    .ctrl-btn.play-btn { width: 52px; height: 52px; font-size: 1.3rem; }
    input[type=range].vol-slider { width: 50px; }
    .pl-thumb { width: 44px; height: 62px; }
  }

  /* ── DESKTOP ── */
  @media (min-width: 900px) {
    .layout { flex-direction: row; align-items: flex-start; }
    .video-col { flex: 1; position: sticky; top: 56px; }
    .side-panel { width: 320px; flex-shrink: 0; }
    .video-wrapper { aspect-ratio: 16/9; }
  }

  /* scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* fullscreen */
  :fullscreen .overlay, :-webkit-full-screen .overlay { opacity: 1; }
</style>
</head>
