// ── STATE ──
let currentIdx = -1;
let hls = null;
let ctrlTimeout = null;

const vid = document.getElementById('vid');
const vwrap = document.getElementById('vwrap');
const overlay = document.getElementById('overlay');
const spinner = document.getElementById('spinner');
const errMsg = document.getElementById('errMsg');
const errTxt = document.getElementById('errTxt');
const nowTitle = document.getElementById('nowTitle');
const btnPlay = document.getElementById('btnPlay');
const btnMute = document.getElementById('btnMute');
const btnFS = document.getElementById('btnFS');
const btnPrev = document.getElementById('btnPrev');
const btnNext = document.getElementById('btnNext');
const progFill = document.getElementById('progFill');
const progWrap = document.getElementById('progWrap');
const timeTxt = document.getElementById('timeTxt');
const volSlider = document.getElementById('volSlider');
const plEl = document.getElementById('playlist');
const urlInput = document.getElementById('urlInput');
const plCount = document.getElementById('plCount');

// ── BUILD PLAYLIST ──
function buildPlaylist() {
  plEl.innerHTML = '';
  items.forEach((item, i) => {
    const div = document.createElement('div');
    div.className = 'pl-item' + (i === currentIdx ? ' active' : '');
    div.innerHTML = `
      <img class="pl-thumb" src="${item.logo || ''}" onerror="this.src=''" alt="">
      <div class="pl-info">
        <div class="pl-name">${item.name}</div>
        <div class="pl-group">${item.group || ''}</div>
      </div>
      <span class="pl-badge">กำลังเล่น</span>
    `;
    div.onclick = () => play(i);
    plEl.appendChild(div);
  });
  plCount.textContent = items.length + ' รายการ';
}

// ── PLAY ──
function play(idx) {
  if (idx < 0 || idx >= items.length) return;
  currentIdx = idx;
  const item = items[idx];

  errMsg.classList.remove('active');
  spinner.classList.add('active');
  nowTitle.textContent = item.name;
  document.title = '▶ ' + item.name;

  if (hls) { hls.destroy(); hls = null; }
  vid.src = '';

  if (Hls.isSupported()) {
    hls = new Hls({
      xhrSetup: xhr => {
        // referrer header via proxy workaround (best-effort)
        try { xhr.setRequestHeader('Referer', REFERRER); } catch(e) {}
      }
    });
    hls.loadSource(item.url);
    hls.attachMedia(vid);
    hls.on(Hls.Events.MANIFEST_PARSED, () => {
      spinner.classList.remove('active');
      vid.play().catch(() => {});
    });
    hls.on(Hls.Events.ERROR, (_, data) => {
      if (data.fatal) {
        spinner.classList.remove('active');
        errTxt.textContent = 'HLS Error: ' + (data.details || 'ไม่สามารถโหลดได้');
        errMsg.classList.add('active');
      }
    });
  } else if (vid.canPlayType('application/vnd.apple.mpegurl')) {
    // Safari / iOS native HLS
    vid.src = item.url;
    vid.load();
    vid.play().catch(() => {});
    spinner.classList.remove('active');
  } else {
    spinner.classList.remove('active');
    errTxt.textContent = 'เบราว์เซอร์ไม่รองรับ HLS';
    errMsg.classList.add('active');
  }

  buildPlaylist();
  showCtrl();
}

// ── CONTROLS ──
function showCtrl() {
  vwrap.classList.add('show-ctrl');
  clearTimeout(ctrlTimeout);
  ctrlTimeout = setTimeout(() => vwrap.classList.remove('show-ctrl'), 3500);
}

vwrap.addEventListener('touchstart', showCtrl, { passive: true });
vwrap.addEventListener('mousemove', showCtrl);

btnPlay.onclick = () => { vid.paused ? vid.play() : vid.pause(); showCtrl(); };
btnMute.onclick = () => { vid.muted = !vid.muted; updateMute(); };
btnPrev.onclick = () => play(currentIdx - 1);
btnNext.onclick = () => play(currentIdx + 1);

// double-tap for mobile seek
let lastTap = 0;
vwrap.addEventListener('touchend', e => {
  const now = Date.now();
  if (now - lastTap < 280) {
    const rect = vwrap.getBoundingClientRect();
    const x = e.changedTouches[0].clientX - rect.left;
    if (x < rect.width * 0.35) { vid.currentTime -= 10; showCtrl(); }
    else if (x > rect.width * 0.65) { vid.currentTime += 10; showCtrl(); }
    else { vid.paused ? vid.play() : vid.pause(); }
  }
  lastTap = now;
}, { passive: true });

// Volume
volSlider.oninput = () => { vid.volume = parseFloat(volSlider.value); vid.muted = false; updateMute(); };

function updateMute() {
  btnMute.textContent = (vid.muted || vid.volume === 0) ? '🔇' : vid.volume < .4 ? '🔈' : '🔊';
}

// Fullscreen
btnFS.onclick = () => {
  if (!document.fullscreenElement && !document.webkitFullscreenElement) {
    (vwrap.requestFullscreen || vwrap.webkitRequestFullscreen).call(vwrap);
  } else {
    (document.exitFullscreen || document.webkitExitFullscreen).call(document);
  }
};

// Progress
vid.addEventListener('timeupdate', () => {
  if (!vid.duration) return;
  const p = (vid.currentTime / vid.duration) * 100;
  progFill.style.width = p + '%';
  timeTxt.textContent = fmt(vid.currentTime) + ' / ' + fmt(vid.duration);
});

progWrap.addEventListener('click', e => {
  if (!vid.duration) return;
  const rect = progWrap.getBoundingClientRect();
  vid.currentTime = ((e.clientX - rect.left) / rect.width) * vid.duration;
});

// touch scrub
progWrap.addEventListener('touchmove', e => {
  if (!vid.duration) return;
  e.preventDefault();
  const rect = progWrap.getBoundingClientRect();
  const x = Math.min(Math.max(e.touches[0].clientX - rect.left, 0), rect.width);
  vid.currentTime = (x / rect.width) * vid.duration;
}, { passive: false });

vid.addEventListener('play', () => { btnPlay.textContent = '⏸'; });
vid.addEventListener('pause', () => { btnPlay.textContent = '▶'; });
vid.addEventListener('waiting', () => spinner.classList.add('active'));
vid.addEventListener('playing', () => spinner.classList.remove('active'));
vid.addEventListener('ended', () => { if (currentIdx + 1 < items.length) play(currentIdx + 1); });
vid.addEventListener('volumechange', updateMute);

function fmt(s) {
  if (!isFinite(s)) return '0:00';
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = Math.floor(s % 60);
  return h ? `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}` : `${m}:${String(sec).padStart(2,'0')}`;
}

// ── KEYBOARD / REMOTE ──
document.addEventListener('keydown', e => {
  const tag = document.activeElement.tagName;
  if (tag === 'INPUT' || tag === 'TEXTAREA') return;
  switch(e.key) {
    case ' ': case 'k': e.preventDefault(); vid.paused ? vid.play() : vid.pause(); break;
    case 'ArrowRight': case 'MediaFastForward': vid.currentTime += 5; break;
    case 'ArrowLeft': case 'MediaRewind': vid.currentTime -= 5; break;
    case 'ArrowUp': vid.volume = Math.min(1, vid.volume + .1); volSlider.value = vid.volume; break;
    case 'ArrowDown': vid.volume = Math.max(0, vid.volume - .1); volSlider.value = vid.volume; break;
    case 'n': case 'N': case 'MediaTrackNext': play(currentIdx + 1); break;
    case 'p': case 'P': case 'MediaTrackPrevious': play(currentIdx - 1); break;
    case 'f': case 'F': btnFS.click(); break;
    case 'm': case 'M': case 'VolumeMute': vid.muted = !vid.muted; break;
    case 'Enter': case 'MediaPlay': case 'MediaPause': vid.paused ? vid.play() : vid.pause(); break;
  }
  showCtrl();
});

// ── ADD URL ──
function addUrl() {
  const raw = urlInput.value.trim();
  if (!raw) return;
  let name = 'วิดีโอ ' + (items.length + 1);
  let url = raw;
  if (raw.includes('::')) {
    const parts = raw.split('::');
    name = parts[0].trim();
    url = parts[1].trim();
  }
  items.push({ name, group: 'เพิ่มเอง', logo: '', url });
  buildPlaylist();
  urlInput.value = '';
  // auto-play if nothing playing
  if (currentIdx === -1) play(items.length - 1);
}

urlInput.addEventListener('keydown', e => { if (e.key === 'Enter') addUrl(); });

// ── INIT ──
buildPlaylist();
</script>
</body>
